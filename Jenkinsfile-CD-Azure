pipeline {
    agent any

    environment {
        SSH_CREDENTIALS_ID = 'azure-master-ssh'
        AZURE_MASTER_IP = '4.165.102.142'
        AZURE_USER = 'azureuser'
        PROJECT_DIR = 'freelink'
        GIT_REPO = 'https://github.com/sophiegafsi/-Esprit--PI---4SAE6---2025-2026---Smart-Freelance-Project-Matching-Platform-.git'
        BRANCH = 'main'
        NAMESPACE = 'freelink'
    }

    stages {
        stage('Deploy to Azure Kubernetes') {
            steps {
                sshagent(credentials: [SSH_CREDENTIALS_ID]) {
                    sh """
                    ssh -o StrictHostKeyChecking=no ${AZURE_USER}@${AZURE_MASTER_IP} '
                        # Check if directory exists, if not clone it
                        if [ ! -d ${PROJECT_DIR} ]; then
                            git clone -b ${BRANCH} ${GIT_REPO} ${PROJECT_DIR}
                        fi
                        
                        cd ${PROJECT_DIR}
                        
                        # Fetch latest changes
                        git pull origin ${BRANCH}
                        
                        # Apply Kubernetes manifests
                        kubectl apply -f k8s/
                        
                        # Restart deployments to pull latest images
                        kubectl rollout restart deployment -n ${NAMESPACE}
                        
                        # Status check
                        kubectl get pods -n ${NAMESPACE}
                        kubectl get svc -n ${NAMESPACE}
                    '
                    """
                }
            }
        }
    }

    post {
        success {
            echo 'Azure Kubernetes deployment successful'
        }
        failure {
            echo 'Azure Kubernetes deployment failed'
        }
    }
}
