pipeline {
    agent any

    tools {
        maven 'Maven-3.9'
        jdk 'Java-17'
    }

    environment {
        SERVICE_NAME = 'api-gateway'
        SERVICE_FOLDER = 'API-Gateway/API-Gateway'
        IMAGE_NAME = 'dalirom123/api-gateway'
        IMAGE_TAG = 'latest'
        DOCKER_CREDENTIALS_ID = 'dockerhub-credentials'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Test') {
            steps {
                dir("${SERVICE_FOLDER}") {
                    sh 'mvn clean install'
                }
            }
        }

        stage('Unit Tests + JaCoCo') {
            steps {
                dir("${SERVICE_FOLDER}") {
                    sh 'mvn org.jacoco:jacoco-maven-plugin:prepare-agent test org.jacoco:jacoco-maven-plugin:report'
                }
            }
            post {
                always {
                    dir("${SERVICE_FOLDER}") {
                        junit testResults: 'target/surefire-reports/*.xml', allowEmptyResults: true
                    }
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir("${SERVICE_FOLDER}") {
                    withSonarQubeEnv('SonarQube') {
                        sh "mvn sonar:sonar -Dsonar.projectKey=${SERVICE_NAME} -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml"
                    }
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir("${SERVICE_FOLDER}") {
                    script {
                        dockerImage = docker.build("${IMAGE_NAME}:${IMAGE_TAG}")
                    }
                }
            }
        }

        stage('Docker Push') {
            steps {
                script {
                    docker.withRegistry('https://index.docker.io/v1/', "${DOCKER_CREDENTIALS_ID}") {
                        dockerImage.push()
                        dockerImage.push('latest')
                    }
                }
            }
        }

        stage('Trigger Global CD') {
            steps {
                build job: 'Global-CD', wait: false
            }
        }
    }

    post {
        success {
            echo "${SERVICE_NAME} CI completed successfully."
        }
        failure {
            echo "${SERVICE_NAME} CI failed."
        }
    }
}
