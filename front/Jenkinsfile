pipeline {
    agent any
    
    environment {
        SERVICE_NAME = 'front'
        DOCKER_CREDENTIALS_ID = 'dockerhub-credentials'
        DOCKER_IMAGE = "dalirom123/front:${env.BUILD_NUMBER}"
        SONAR_CREDENTIALS_ID = 'sonar-credentials'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Install Dependencies') {
            steps {
                dir('front/sofia-pidev-front-Gestion-skills') {
                    sh '''
                        rm -rf node_modules package-lock.json
                        npm config delete prefix || true
                        npm config delete cache || true
                        npm config set cache /tmp/npm-cache
                        npm install --legacy-peer-deps
                    '''
                }
            }
        }
        
        stage('Test (Jasmine)') {
            steps {
                dir('front/sofia-pidev-front-Gestion-skills') {
                    sh 'npm run test -- --watch=false --browsers=ChromeHeadless'
                }
            }
        }
        
        stage('Build') {
            steps {
                dir('front/sofia-pidev-front-Gestion-skills') {
                    sh 'npm run build'
                }
            }
        }
        
        stage('SonarQube Analysis') {
            steps {
                dir('front/sofia-pidev-front-Gestion-skills') {
                    withSonarQubeEnv('SonarQube') {
                        sh 'npx sonar-scanner -Dsonar.projectKey=${SERVICE_NAME} -Dsonar.sources=src'
                    }
                }
            }
        }
        
        stage('Build Docker Image') {
            steps {
                dir('front/sofia-pidev-front-Gestion-skills') {
                    script {
                        dockerImage = docker.build("${DOCKER_IMAGE}")
                    }
                }
            }
        }
        
        stage('Push Docker Image') {
            steps {
                script {
                    docker.withRegistry('https://index.docker.io/v1/', "${DOCKER_CREDENTIALS_ID}") {
                        dockerImage.push()
                        dockerImage.push('latest')
                    }
                }
            }
        }
    }
}
